//1784. Check if Binary String Has at Most One Segment of Ones in java..



class Solution {
    public boolean checkOnesSegment(String s) {


        //Approach 1 
        int n = s.length();
        int count = 0;
        for(int i = 0; i<n; i++){
            if(s.charAt(i) == '1'){
                count++;//new Segment

               // For continous 1's we need to fix count = 1  so skip i's...
                while(i<n && s.charAt(i)=='1'){
                    i++;
                }
                i--; //adjust for loop
            }
        }

        if(count>1) return false;

        return true;

        //Approach 2
        return !s.contains("01");
        
    }
}
