//215. Kth Largest Element in an Array in java..


class Solution {
    public int findKthLargest(int[] nums, int k) {
        PriorityQueue<Integer> pq = new PriorityQueue<>();

        for(int n : nums){
            pq.add(n);
            if(pq.size() > k){
                pq.poll();// Remove min element in min heap to maintain size  k 
            }
        }
        return pq.peek();//The root of min heap is kth largest element
        
    }
}
