        // return ans ;



        //Approach 1 :  Brute force TC is O(n*m*(n+m))....
        int n = mat.length;
        int m = mat[0].length;
        int count = 0;

        for(int i =0; i<n; i++){
            for(int j = 0; j<m ; j++){
                if(mat[i][j]==1){
                    if(valid(i,j,n,m,mat)){
                        count++;
                    }
                }
            }
        }
        return count;
        
    }

    private boolean valid(int i , int j, int n ,int m, int[][] mat){
        for(int t = 0; t<n; t++){
            if(t != i && mat[t][j]==1){
                return false;
            }

        }
        for(int t = 0; t<m; t++){
            if(t != j && mat[i][t]==1){
                return false;
            }
            
        }
        return true;
    }
}
