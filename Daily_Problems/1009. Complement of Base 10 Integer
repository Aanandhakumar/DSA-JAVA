//1009. Complement of Base 10 Integer in java..

// Approach 1 ..
class Solution {
    public int bitwiseComplement(int n) {
        StringBuilder sb = new StringBuilder();
        String s = Integer.toBinaryString(n);
        for(char c : s.toCharArray()){
            if(c=='0'){
                sb.append('1');
            }else{
                sb.append('0');
            }
        }
        int ans = Integer.parseInt(sb.toString(),2);
        return ans;

        
    }
}

//Approach 2...
class Solution {
    public int bitwiseComplement(int n) {
        if(n == 0) return 1;
        int mask = 0;
        int temp = n;
        while(temp>0){
            mask = (mask<<1) | 1;
            temp >>= 1;
        }
        return n ^ mask;
        
    }
}

//Approach 3...
class Solution {
    public int bitwiseComplement(int n) {
        if(n==0) return 1;
       int mask = (Integer.highestOneBit(n)<<1) -1;
        return n ^ mask;
        
    }
}
