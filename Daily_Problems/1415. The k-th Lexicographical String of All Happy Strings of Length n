//1415. The k-th Lexicographical String of All Happy Strings of Length n in java...


class Solution {
    private int count = 0;
    private String result = "";
    public String getHappyString(int n, int k) {
        backtrack(n,k,new StringBuilder(),' ');
        return result;
        
    }

    private void backtrack(int n, int k , StringBuilder sb , char lastchar){
        if(sb.length() == n){
            count++;
            if(count == k){
                result = sb.toString();

            }
            return ;
        }

        for(char ch : "abc".toCharArray()){
            if(ch != lastchar){
                sb.append(ch);
                backtrack(n,k,sb,ch);
                sb.deleteCharAt(sb.length()-1);
            }
        }
    }
}
