//1545. Find Kth Bit in Nth Binary String in java....


class Solution {
    public char findKthBit(int n, int k) {

         //Approach 1..
        if(k == 1){
            return '0';
        }
        StringBuilder sb = new StringBuilder();
        sb.append('0');

        for(int i = 0; i<n; i++){
            StringBuilder rsb = new StringBuilder();
            for(int j = 0; j<sb.length(); j++){
                if(sb.charAt(j) == '0'){
                    rsb.append('1');
                }else{
                    rsb.append('0');
                }
            }
            sb.append('1');
            sb.append(rsb.reverse());
            if(sb.length() >= k){
               return sb.charAt(k-1);
            }

        }

        
        return '0';


        //Approach 2 better than 1..
        if (n == 1) {
            return '0';
        }
        int length = (1 << n) - 1;
        int mid = (length / 2) + 1;
        if (k == mid) {
            return '1';
        }
        if (k < mid) {
            return findKthBit(n - 1, k);
        }
        char inveredBit = findKthBit(n - 1, length - k + 1);
        return inveredBit == '0' ? '1' : '0';

    }
}
